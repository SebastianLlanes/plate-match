rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /reports/{reportId} {
       allow list: if request.auth != null;
        
        allow read: if request.auth != null &&
          request.auth.uid == resource.data.userId;

      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;

      allow update: if request.auth != null &&
        request.auth.uid == resource.data.userId &&
        request.resource.data.userId == resource.data.userId;

      allow delete: if false;
    }

      match /matches/{matchId} {
      // Permitir query para verificar matches existentes por patente
      allow list: if request.auth != null;
      
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.lostUserId ||
        request.auth.uid == resource.data.foundUserId
      );

      allow create: if request.auth != null && (
        request.auth.uid == request.resource.data.lostUserId ||
        request.auth.uid == request.resource.data.foundUserId
      );

      allow update: if request.auth != null && (
        request.auth.uid == resource.data.lostUserId ||
        request.auth.uid == resource.data.foundUserId
      );

      allow delete: if false;
    }
  }
}
