rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /reports/{reportId} {
  allow read, write: if request.auth != null;
}

match /matches/{matchId} {
  allow read, write: if request.auth != null;
}

    match /matches/{matchId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.lostUserId ||
        request.auth.uid == resource.data.foundUserId
      );

      // Cliente crea matches pero solo si es participante
      allow create: if request.auth != null && (
        request.auth.uid == request.resource.data.lostUserId ||
        request.auth.uid == request.resource.data.foundUserId
      );

      allow update: if request.auth != null && (
        request.auth.uid == resource.data.lostUserId ||
        request.auth.uid == resource.data.foundUserId
      );

      allow delete: if false;
    }
  }
}
